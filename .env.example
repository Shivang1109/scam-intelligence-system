# Application
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=scam_intelligence
DB_USER=scam_user
DB_PASSWORD=changeme123

# Redis (optional)
REDIS_HOST=localhost
REDIS_PORT=6379

# API Configuration
CORS_ORIGIN=*
API_KEY_SECRET=your-secret-key-here

# Test API Key (CHANGE THIS IN PRODUCTION!)
# Generate a secure random key: openssl rand -hex 32
TEST_API_KEY=CHANGE_ME_TO_SECURE_KEY

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Agent Configuration
MAX_CONVERSATION_DURATION_MS=3600000
STALLED_CONVERSATION_THRESHOLD_MS=300000
# OpenAI (Optional - for AI-enhanced detection)
# Get your API key from: https://platform.openai.com/api-keys
# Free tier: $5 credit, then pay-as-you-go
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic Claude (Optional - for natural persona responses)
# Get your API key from: https://console.anthropic.com/
# Free tier: $5 credit, then pay-as-you-go
# Model: claude-3-5-haiku (fast & cheap: ~$0.0001/response)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
